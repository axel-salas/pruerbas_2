        "#| label: setup1\n",
        "#| include: false\n",
        "\n",
        "import plotly.graph_objects as go\n",
        "import plotly.express as px\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from IPython.display import display\n",
        "\n",
        "# ── Paleta ───────────────────────────────────\n",
        "C_DEEP  = \"#03045E\"\n",
        "C_MID   = \"#0077B6\"\n",
        "C_LIGHT = \"#00B4D8\"\n",
        "C_FOAM  = \"#90E0EF\"\n",
        "C_MIST  = \"#CAF0F8\"\n",
        "C_CORAL = \"#F4A261\"\n",
        "C_TEAL  = \"#2A9D8F\"\n",
        "\n",
        "# ── Fondo transparente para gráficos (encajan con el tema oscuro) ──\n",
        "_bg = dict(\n",
        "    plot_bgcolor=\"rgba(0,0,0,0)\",\n",
        "    paper_bgcolor=\"rgba(0,0,0,0)\",\n",
        "    font_color=\"#cce8f4\",\n",
        ")\n",
        "\n",
        "# ═══════════════════════════════════════════════\n",
        "#  CARGA DE DATOS\n",
        "# ═══════════════════════════════════════════════\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "ballenas = pd.read_csv('../datos/ballenas/ballenas.csv').iloc[:28]\n",
        "ballenas.columns = ['año', 'poblacion registrada']\n",
        "ballenas['poblacion registrada'] = ballenas['poblacion registrada'].str.replace(',', '').astype(float)\n",
        "ballenas['año'] = pd.to_numeric(ballenas['año'])\n",
        "\n",
        "pelicanos = pd.read_csv('../datos/pelicanos/pelicanos.csv').iloc[:22, :2]\n",
        "pelicanos.columns = ['año', 'cantidad_nidos_pelicanos']\n",
        "pelicanos['año'] = pelicanos['año'].astype(str)\n",
        "\n",
        "produccion_pesquera = pd.read_csv(\n",
        "    '../datos/produccion_pesquera/produccion_pesquera.csv',\n",
        "    header=None, names=['año', 'toneladas_pescadas']\n",
        ")\n",
        "produccion_pesquera['toneladas_pescadas'] = produccion_pesquera['toneladas_pescadas'].str.replace(',', '').astype(float)\n",
        "produccion_pesquera['año'] = produccion_pesquera['año'].astype(float)\n",
        "\n",
        "embarcaciones = pd.read_csv('../datos/embarcaciones/total_embarcaciones.csv').iloc[:36]\n",
        "embarcaciones['total_embarcaciones'] = embarcaciones['total_embarcaciones'].str.replace(',', '').astype(float)\n",
        "embarcaciones['año'] = pd.to_numeric(embarcaciones['año'])\n",
        "\n",
        "# ═══════════════════════════════════════════════\n",
        "#  FRANJAS EL NIÑO (compartidas entre figuras)\n",
        "# ═══════════════════════════════════════════════\n",
        "\n",
        "el_nino_periods = [\n",
        "    (2002, 2003), (2004, 2005), (2006, 2007),\n",
        "    (2009, 2010), (2014, 2016), (2018, 2019)\n",
        "]\n",
        "\n",
        "shapes_nino = [\n",
        "    dict(\n",
        "        type=\"rect\", x0=s, x1=e, y0=0, y1=1,\n",
        "        xref=\"x\", yref=\"paper\",\n",
        "        fillcolor=\"rgba(244, 162, 97, 0.15)\",\n",
        "        line_width=0, layer=\"below\"\n",
        "    )\n",
        "    for s, e in el_nino_periods\n",
        "]\n",
        "\n",
        "# ═══════════════════════════════════════════════\n",
        "#  FUNCIONES DE FIGURAS\n",
        "# ═══════════════════════════════════════════════\n",
        "\n",
        "def crear_fig_ballenas(df):\n",
        "    fig = go.Figure()\n",
        "\n",
        "    # Leyenda El Niño\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=[None], y=[None], mode='markers',\n",
        "        marker=dict(symbol=\"square\", size=15, color=\"rgba(244,162,97,0.3)\"),\n",
        "        name='Fenómeno de El Niño (Calentamiento)', showlegend=True\n",
        "    ))\n",
        "\n",
        "    # Serie principal\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=df['año'], y=df['poblacion registrada'],\n",
        "        mode='lines+markers', name='Avistamientos',\n",
        "        line=dict(color=C_MID, width=3, shape='spline'),\n",
        "        marker=dict(size=8, color=C_DEEP, symbol='circle'),\n",
        "        fill='tozeroy', fillcolor='rgba(0,180,216,0.15)',\n",
        "        hovertemplate=\"<b>Año:</b> %{x}<br><b>Individuos:</b> %{y:,.0f}<extra></extra>\"\n",
        "    ))\n",
        "\n",
        "    fig.add_annotation(x=2012, y=3070, text=\"<b>Máximo histórico</b>\",\n",
        "        showarrow=True, arrowhead=2, ax=0, ay=-40,\n",
        "        font=dict(color=C_TEAL, size=12))\n",
        "    fig.add_annotation(x=2020, y=980, text=\"<b>Mínimo histórico</b>\",\n",
        "        showarrow=True, arrowhead=2, ax=0, ay=30,\n",
        "        font=dict(color=\"#C62828\", size=12))\n",
        "\n",
        "    fig.update_layout(\n",
        "        **_bg,\n",
        "        shapes=shapes_nino,\n",
        "        title=dict(\n",
        "            text=\"<b>Monitoreo de Ballenas en Baja California</b>\"\n",
        "                 \"<br><span style='font-size:13px;color:#7ab4cc;'>\"\n",
        "                 \"El impacto de la temperatura oceánica en la migración</span>\",\n",
        "            y=0.96, x=0.02, xanchor='left', yanchor='top'\n",
        "        ),\n",
        "        xaxis_title=\"Temporada (Año)\",\n",
        "        yaxis_title=\"Individuos Registrados\",\n",
        "        hovermode=\"x unified\",\n",
        "        legend=dict(orientation=\"h\", y=1.05, yanchor=\"bottom\", x=1, xanchor=\"right\"),\n",
        "        margin=dict(l=60, r=30, t=100, b=60),\n",
        "        height=420\n",
        "    )\n",
        "    fig.update_xaxes(tickformat=\".0f\", tickangle=0, dtick=4, showgrid=False,\n",
        "                     color=\"#7ab4cc\", linecolor=\"rgba(93,214,240,0.2)\")\n",
        "    fig.update_yaxes(showgrid=True, gridcolor='rgba(93,214,240,0.12)',\n",
        "                     tickformat=\",\", color=\"#7ab4cc\")\n",
        "    return fig\n",
        "\n",
        "\n",
        "def crear_fig_pelicanos(df):\n",
        "    fig = go.Figure()\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=[None], y=[None], mode='markers',\n",
        "        marker=dict(symbol=\"square\", size=15, color=\"rgba(244,162,97,0.3)\"),\n",
        "        name='Fenómeno de El Niño', showlegend=True\n",
        "    ))\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=df['año'], y=df['cantidad_nidos_pelicanos'],\n",
        "        mode='lines+markers', name='Nidos Activos',\n",
        "        line=dict(color=C_TEAL, width=3, shape='spline'),\n",
        "        marker=dict(size=8, color=C_DEEP, symbol='circle'),\n",
        "        fill='tozeroy', fillcolor='rgba(42,157,143,0.15)',\n",
        "        hovertemplate=\"<b>Año:</b> %{x}<br><b>Nidos:</b> %{y:,.0f}<extra></extra>\"\n",
        "    ))\n",
        "\n",
        "    fig.add_annotation(x='2011', y=30400, text=\"<b>Máximo histórico</b>\",\n",
        "        showarrow=True, arrowhead=2, ax=0, ay=-40,\n",
        "        font=dict(color=C_TEAL, size=12))\n",
        "\n",
        "    # shapes_nino usa xref=\"x\" numérico; pelícanos tiene eje categórico\n",
        "    # → solo añadimos si el eje es compatible\n",
        "    fig.update_layout(\n",
        "        **_bg,\n",
        "        title=dict(\n",
        "            text=\"<b>Dinámica Reproductiva: Pelícano Pardo</b>\"\n",
        "                 \"<br><span style='font-size:13px;color:#7ab4cc;'>\"\n",
        "                 \"Impacto de la variabilidad oceánica en la anidación</span>\",\n",
        "            y=0.96, x=0.02, xanchor='left', yanchor='top'\n",
        "        ),\n",
        "        xaxis_title=\"Temporada (Año)\",\n",
        "        yaxis_title=\"Cantidad de Nidos\",\n",
        "        hovermode=\"x unified\",\n",
        "        legend=dict(orientation=\"h\", y=1.05, yanchor=\"bottom\", x=1, xanchor=\"right\"),\n",
        "        margin=dict(l=60, r=30, t=100, b=60),\n",
        "        height=420\n",
        "    )\n",
        "    fig.update_xaxes(tickangle=0, dtick=3, showgrid=False,\n",
        "                     color=\"#7ab4cc\", linecolor=\"rgba(93,214,240,0.2)\")\n",
        "    fig.update_yaxes(showgrid=True, gridcolor='rgba(93,214,240,0.12)',\n",
        "                     tickformat=\",\", color=\"#7ab4cc\")\n",
        "    return fig\n",
        "\n",
        "\n",
        "def crear_fig_pesca(df):\n",
        "    fig = go.Figure()\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=df['año'], y=df['toneladas_pescadas'],\n",
        "        mode='lines+markers', name='Producción (Ton)',\n",
        "        line=dict(color='#C62828', width=3, shape='spline'),\n",
        "        marker=dict(size=8, color='#B71C1C', symbol='diamond'),\n",
        "        fill='tozeroy', fillcolor='rgba(198,40,40,0.1)',\n",
        "        hovertemplate=\"<b>Año:</b> %{x}<br><b>Captura:</b> %{y:,.0f} ton<extra></extra>\"\n",
        "    ))\n",
        "\n",
        "    max_ton  = df['toneladas_pescadas'].max()\n",
        "    max_year = df.loc[df['toneladas_pescadas'].idxmax(), 'año']\n",
        "    fig.add_annotation(x=max_year, y=max_ton, text=\"<b>Pico máximo histórico</b>\",\n",
        "        showarrow=True, arrowhead=2, ax=-40, ay=-30,\n",
        "        font=dict(color=\"#E53935\", size=12))\n",
        "\n",
        "    fig.update_layout(\n",
        "        **_bg,\n",
        "        title=dict(text=\"<b>Extracción Pesquera en Baja California</b>\",\n",
        "                   y=0.96, x=0.02, xanchor='left', yanchor='top'),\n",
        "        xaxis_title=\"Año\", yaxis_title=\"Toneladas\",\n",
        "        hovermode=\"x unified\",\n",
        "        margin=dict(l=60, r=30, t=70, b=50),\n",
        "        height=320\n",
        "    )\n",
        "    fig.update_xaxes(tickangle=0, dtick=4, showgrid=False,\n",
        "                     color=\"#7ab4cc\", linecolor=\"rgba(93,214,240,0.2)\")\n",
        "    fig.update_yaxes(tickformat=\",\", showgrid=True,\n",
        "                     gridcolor='rgba(93,214,240,0.12)', color=\"#7ab4cc\")\n",
        "    return fig\n",
        "\n",
        "\n",
        "def crear_fig_embarcaciones(df):\n",
        "    fig = go.Figure()\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=df['año'], y=df['total_embarcaciones'],\n",
        "        mode='lines+markers', name='Total Embarcaciones',\n",
        "        line=dict(color='#E65100', width=3, shape='spline'),\n",
        "        marker=dict(size=8, color='#BF360C', symbol='diamond'),\n",
        "        fill='tozeroy', fillcolor='rgba(230,81,0,0.1)',\n",
