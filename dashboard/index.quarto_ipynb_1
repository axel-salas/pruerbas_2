      "source": [
        "#| label: setup2\n",
        "#| include: false\n",
        "\n",
        "import numpy as np\n",
        "import plotly.graph_objects as go\n",
        "from IPython.display import display\n",
        "import json\n",
        "import os\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ── 1. DATOS Y PARÁMETROS ────────────────────────────────────────────────────\n",
        "\n",
        "H_OBS = np.array([\n",
        "    0.3955, 0.2110, 0.1324, 0.2965, 0.1371, 0.7856, 0.6301, 0.7755,\n",
        "    0.1915, 0.2478, 0.1508, 0.0019, 0.7141, 1.0000, 0.3317, 0.5094,\n",
        "    0.5473, 0.4663, 0.2647, 0.3063, 0.0490, 0.0000, 0.1266, 0.0481,\n",
        "    0.1683, 0.1683\n",
        "])\n",
        "P_OBS = np.array([\n",
        "    0.2620, 0.3156, 0.2890, 0.3070, 0.2879, 0.2694, 0.2575, 0.2641,\n",
        "    0.2496, 0.1191, 0.1842, 0.2185, 0.1624, 0.2637, 0.0000, 0.3311,\n",
        "    0.1241, 0.1882, 0.3972, 0.6336, 0.5479, 0.6653, 0.5310, 0.7614,\n",
        "    0.7429, 1.0000\n",
        "])\n",
        "\n",
        "T_PROJ  = 100\n",
        "AÑO_INI = 1999\n",
        "AÑOS    = np.arange(AÑO_INI, AÑO_INI + T_PROJ)\n",
        "N_HIST  = len(H_OBS)\n",
        "\n",
        "GRID_A  = np.array([0.20, 0.40, 0.60, 0.80, 1.00, 1.20, 1.40, 1.60, 1.80, 2.00])\n",
        "GRID_F  = np.array([0.20, 0.40, 0.60, 0.80, 1.00, 1.20, 1.40, 1.60, 1.80, 2.00])\n",
        "GRID_YR = np.array([2025, 2027, 2030, 2032, 2035, 2037, 2040])\n",
        "\n",
        "# ── Paleta integrada con el tema marino del custom.scss ──────────────────────\n",
        "# Fondos transparentes → hereda el glass-card del tema\n",
        "# Colores de datos alineados a la paleta ODS-14\n",
        "COLORES = {\n",
        "    'H_cons':  '#1DB38A',               # verde-teal (biodiversidad recuperándose)\n",
        "    'H_iner':  '#E05C2A',               # naranja-rojo (escenario inercial)\n",
        "    'P_cons':  '#5dd6f0',               # foam del tema (flota bajo control)\n",
        "    'P_iner':  '#f4a261',               # warning del tema (flota descontrolada)\n",
        "    'hist_H':  '#1DB38A',\n",
        "    'hist_P':  '#E05C2A',\n",
        "    # Fondos: transparentes para encajar sobre .bslib-card\n",
        "    'bg':      'rgba(0,0,0,0)',         # papel transparente\n",
        "    'ax':      'rgba(6,48,82,0.45)',    # área de plot azul profundo\n",
        "    'grid':    'rgba(93,214,240,0.12)', # cuadrícula cian muy suave\n",
        "    'text':    '#cce8f4',               # --text-main del tema\n",
        "    # Sliders (SVG inline — se controlan vía dict en Plotly)\n",
        "    'sl_bg':   '#041e35',               # fondo del slider = $deep\n",
        "    'sl_bord': '#1278b0',               # borde del slider = $wave\n",
        "    'sl_tick': '#5dd6f0',               # ticks del slider = $foam\n",
        "}\n",
        "\n",
        "# ── 2. CARGA DE DATOS PRECOMPUTADOS ──────────────────────────────────────────\n",
        "\n",
        "PATH_CACHE = '../datos/cache_modelo/cache_escenarios.json'\n",
        "\n",
        "if not os.path.exists(PATH_CACHE):\n",
        "    raise FileNotFoundError(f\"No se encontró el archivo de caché en: {PATH_CACHE}\")\n",
        "\n",
        "with open(PATH_CACHE, 'r') as f:\n",
        "    datos_crudos = json.load(f)\n",
        "\n",
        "CACHE = {}\n",
        "for k, v in datos_crudos.items():\n",
        "    try:\n",
        "        fa, ff, yr = k.split('_')\n",
        "        key = (round(float(fa), 2), round(float(ff), 2), int(yr))\n",
        "        CACHE[key] = v\n",
        "    except ValueError:\n",
        "        continue\n",
        "\n",
        "# ── 3. CONSTRUCCIÓN DE FIGURAS ────────────────────────────────────────────────\n",
        "\n",
        "AÑOS_OBS  = list(AÑOS[:N_HIST])\n",
        "AÑOS_FULL = list(AÑOS)\n",
        "IDX_BASE  = 4   # índice central de los grids (factor = 1.00)\n",
        "\n",
        "\n",
        "def ganancia_txt(d, dk, di):\n",
        "    hi_fin = float(np.mean(d[di]['med'][-10:]))\n",
        "    hc_fin = float(np.mean(d[dk]['med'][-10:]))\n",
        "    g = (hc_fin - hi_fin) / max(hi_fin, 0.001) * 100\n",
        "    signo = '+' if g >= 0 else ''\n",
        "    return (f\"Proyectado: {hc_fin:.3f}  |  Inercial: {hi_fin:.3f}  \"\n",
        "            f\"|  Diferencia: {signo}{g:.1f}%\")\n",
        "\n",
        "\n",
        "def construir_figura(variable='H'):\n",
        "    assert variable in ('H', 'P')\n",
        "    es_H     = variable == 'H'\n",
        "    col_cons = COLORES['H_cons'] if es_H else COLORES['P_cons']\n",
        "    col_iner = COLORES['H_iner'] if es_H else COLORES['P_iner']\n",
        "    obs_data = H_OBS if es_H else P_OBS\n",
        "    titulo   = ('H — Biodiversidad marina (presa)' if es_H\n",
        "                 else 'P — Flota pesquera (depredador)')\n",
        "    ytit     = 'H normalizado' if es_H else 'P normalizado'\n",
        "    dk       = 'Hc' if es_H else 'Pc'\n",
        "    di       = 'Hi' if es_H else 'Pi'\n",
        "\n",
        "    # Escenario por defecto\n",
        "    fa0, ff0, yr0 = round(GRID_A[IDX_BASE], 2), round(GRID_F[IDX_BASE], 2), 2030\n",
        "    key0 = (fa0, ff0, yr0)\n",
        "    if key0 not in CACHE:\n",
        "        key0 = list(CACHE.keys())[0]\n",
        "    d0 = CACHE[key0]\n",
        "\n",
        "    fig = go.Figure()\n",
        "\n",
        "    # Datos históricos\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=AÑOS_OBS, y=list(obs_data),\n",
        "        mode='markers',\n",
        "        marker=dict(color='white', size=7, line=dict(color=col_cons, width=1.5)),\n",
        "        name='Datos históricos',\n",
        "        hovertemplate='Año: %{x}<br>Valor: %{y:.3f}<extra></extra>',\n",
        "    ))\n",
        "\n",
        "    # Escenario inercial (referencia)\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=AÑOS_FULL, y=list(d0[di]['med']),\n",
        "        mode='lines',\n",
        "        line=dict(color=col_iner, width=2, dash='dash'),\n",
        "        name='Inercial (100% presión)',\n",
        "        hovertemplate='Año: %{x}<br>%{y:.3f}<extra>Inercial</extra>',\n",
        "    ))\n",
        "\n",
        "    # Escenario proyectado\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=AÑOS_FULL, y=list(d0[dk]['med']),\n",
        "        mode='lines',\n",
        "        line=dict(color=col_cons, width=2.8),\n",
        "        name='Escenario proyectado',\n",
        "        hovertemplate='Año: %{x}<br>%{y:.3f}<extra>Proyección</extra>',\n",
        "    ))\n",
        "\n",
        "    # Línea vertical de intervención\n",
        "    fig.add_vline(\n",
        "        x=yr0,\n",
        "        line=dict(color='rgba(204,232,244,0.45)', width=1.5, dash='dot'),\n",
        "        annotation=dict(\n",
        "            text='Año de intervención',\n",
        "            font=dict(color=COLORES['text'], size=10),\n",
        "            showarrow=False, yref='paper', y=1.02, xanchor='left'\n",
        "        )\n",
        "    )\n",
        "\n",
        "    # ── Frames animados (uno por combinación del grid) ────────────\n",
        "    frames = []\n",
        "    for fa in GRID_A:\n",
        "        for ff in GRID_F:\n",
        "            for yr in GRID_YR:\n",
        "                key = (round(fa, 2), round(ff, 2), int(yr))\n",
        "                if key in CACHE:\n",
        "                    d = CACHE[key]\n",
        "                    frames.append(go.Frame(\n",
        "                        name=f\"{fa:.2f}_{ff:.2f}_{yr}\",\n",
        "                        data=[\n",
        "                            go.Scatter(x=AÑOS_OBS,  y=list(obs_data)),\n",
        "                            go.Scatter(x=AÑOS_FULL, y=list(d[di]['med'])),\n",
        "                            go.Scatter(x=AÑOS_FULL, y=list(d[dk]['med'])),\n",
        "                        ],\n",
        "                        layout=go.Layout(\n",
        "                            shapes=[dict(\n",
        "                                type='line', x0=yr, x1=yr, y0=0, y1=1,\n",
        "                                xref='x', yref='paper',\n",
        "                                line=dict(color='rgba(204,232,244,0.45)',\n",
        "                                          width=1.5, dash='dot')\n",
        "                            )],\n",
        "                            annotations=[dict(\n",
        "                                xref='paper', yref='paper', x=0.01, y=0.97,\n",
        "                                text=ganancia_txt(d, dk, di),\n",
        "                                font=dict(color=COLORES['text'], size=11),\n",
        "                                showarrow=False,\n",
        "                                bgcolor='rgba(4,30,53,0.88)',\n",
        "                                bordercolor='rgba(93,214,240,0.25)',\n",
        "                                borderpad=6\n",
        "                            )]\n",
        "                        )\n",
        "                    ))\n",
        "    fig.frames = frames\n",
        "\n",
        "    # ── Sliders — colores alineados al tema marino ────────────────\n",
        "    _sl = dict(\n",
        "        bgcolor=COLORES['sl_bg'],\n",
        "        bordercolor=COLORES['sl_bord'],\n",
        "        tickcolor=COLORES['sl_tick'],\n",
        "        font=dict(color=COLORES['text'], size=10),\n",
        "        pad=dict(t=10),\n",
        "        len=0.88, x=0.06,\n",
        "    )\n",
        "\n",
        "    sliders = [\n",
        "        dict(\n",
        "            **_sl, y=-0.15, active=IDX_BASE,\n",
        "            steps=[dict(\n",
        "                method='animate',\n",
        "                args=[[f\"{round(fa,2):.2f}_{round(GRID_F[IDX_BASE],2):.2f}_{GRID_YR[2]}\"],\n",
        "                      dict(mode='immediate',\n",
        "                           frame=dict(duration=0, redraw=True),\n",
        "                           transition=dict(duration=0))],\n",
        "                label=f'{int(fa*100)}%'\n",
        "            ) for fa in GRID_A],\n",
        "            currentvalue=dict(\n",
        "                prefix='Factor presión (a): ',\n",
        "                font=dict(color=COLORES['text'], size=11)\n",
        "            ),\n",
        "        ),\n",
        "        dict(\n",
        "            **_sl, y=-0.35, active=IDX_BASE,\n",
        "            steps=[dict(\n",
        "                method='animate',\n",
        "                args=[[f\"{round(GRID_A[IDX_BASE],2):.2f}_{round(ff,2):.2f}_{GRID_YR[2]}\"],\n",
        "                      dict(mode='immediate',\n",
        "                           frame=dict(duration=0, redraw=True),\n",
        "                           transition=dict(duration=0))],\n",
        "                label=f'{int(ff*100)}%'\n",
        "            ) for ff in GRID_F],\n",
        "            currentvalue=dict(\n",
        "                prefix='Factor crecimiento (f): ',\n",
        "                font=dict(color=COLORES['text'], size=11)\n",
        "            ),\n",
        "        ),\n",
        "        dict(\n",
        "            **_sl, y=-0.55, active=2,\n",
        "            steps=[dict(\n",
        "                method='animate',\n",
        "                args=[[f\"{round(GRID_A[IDX_BASE],2):.2f}_{round(GRID_F[IDX_BASE],2):.2f}_{int(yr)}\"],\n",
        "                      dict(mode='immediate',\n",
        "                           frame=dict(duration=0, redraw=True),\n",
        "                           transition=dict(duration=0))],\n",
        "                label=str(int(yr))\n",
        "            ) for yr in GRID_YR],\n",
        "            currentvalue=dict(\n",
        "                prefix='Año intervención: ',\n",
        "                font=dict(color=COLORES['text'], size=11)\n",
        "            ),\n",
        "        ),\n",
        "    ]\n",
        "\n",
        "    # ── Layout ───────────────────────────────────────────────────\n",
        "    fig.update_layout(\n",
        "        title=dict(\n",
        "            text=titulo,\n",
        "            font=dict(color=COLORES['text'], size=15),\n",
        "            x=0.5, xanchor='center'\n",
        "        ),\n",
        "        # Transparente → hereda el .card-modelo-grafico del SCSS\n",
        "        plot_bgcolor=COLORES['ax'],\n",
        "        paper_bgcolor=COLORES['bg'],\n",
        "        font=dict(color=COLORES['text'], family='DM Sans, system-ui, sans-serif'),\n",
        "        xaxis=dict(\n",
        "            title='Año',\n",
        "            gridcolor=COLORES['grid'],\n",
        "            linecolor='rgba(93,214,240,0.2)',\n",
        "            range=[AÑO_INI - 1, AÑO_INI + T_PROJ],\n",
        "            tickfont=dict(color=COLORES['text'])\n",
        "        ),\n",
        "        yaxis=dict(\n",
        "            title=ytit,\n",
        "            gridcolor=COLORES['grid'],\n",
        "            linecolor='rgba(93,214,240,0.2)',\n",
        "            rangemode='nonnegative',\n",
        "            tickfont=dict(color=COLORES['text'])\n",
        "        ),\n",
        "        legend=dict(\n",
        "            bgcolor='rgba(4,30,53,0.85)',\n",
        "            bordercolor='rgba(93,214,240,0.22)',\n",
        "            borderwidth=1,\n",
        "            orientation='h', y=1.08, x=0.0,\n",
        "            font=dict(color=COLORES['text'])\n",
        "        ),\n",
        "        margin=dict(t=100, b=280, l=60, r=40),\n",
        "        sliders=sliders,\n",
        "        height=750,\n",
        "        hovermode='x unified',\n",
        "    )\n",
        "\n",
        "    return fig"
      ],
      "id": "setup2",
      "execution_count": null,
      "outputs": []
