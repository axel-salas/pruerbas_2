    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: setup3\n",
        "#| include: false\n",
        "\n",
        "import numpy as np\n",
        "import plotly.graph_objects as go\n",
        "from plotly.subplots import make_subplots\n",
        "from IPython.display import display\n",
        "\n",
        "# ── 1. DATOS Y PARÁMETROS BASE ───────────────────────────────────────────────\n",
        "\n",
        "H_OBS = np.array([\n",
        "    0.3955, 0.2110, 0.1324, 0.2965, 0.1371, 0.7856, 0.6301, 0.7755,\n",
        "    0.1915, 0.2478, 0.1508, 0.0019, 0.7141, 1.0000, 0.3317, 0.5094,\n",
        "    0.5473, 0.4663, 0.2647, 0.3063, 0.0490, 0.0000, 0.1266, 0.0481,\n",
        "    0.1683, 0.1683\n",
        "])\n",
        "P_OBS = np.array([\n",
        "    0.2620, 0.3156, 0.2890, 0.3070, 0.2879, 0.2694, 0.2575, 0.2641,\n",
        "    0.2496, 0.1191, 0.1842, 0.2185, 0.1624, 0.2637, 0.0000, 0.3311,\n",
        "    0.1241, 0.1882, 0.3972, 0.6336, 0.5479, 0.6653, 0.5310, 0.7614,\n",
        "    0.7429, 1.0000\n",
        "])\n",
        "\n",
        "# Medianas MCMC\n",
        "R_M  = 1.1564\n",
        "A_M  = 2.045\n",
        "F_M  = 0.0472\n",
        "SH_M = 0.2643\n",
        "SP_M = 0.197\n",
        "K = C = 1.0\n",
        "\n",
        "T        = 100\n",
        "AÑO_INI  = 1999\n",
        "AÑOS     = np.arange(AÑO_INI, AÑO_INI + T)\n",
        "AÑOS_OBS = AÑOS[:len(H_OBS)]\n",
        "N_SIMS   = 300\n",
        "\n",
        "# ── Paleta integrada con el tema marino ──────────────────────────────────────\n",
        "# Fondos transparentes para encajar sobre .bslib-card del custom.scss\n",
        "BG_PLOT = 'rgba(0,0,0,0)'           # hereda el glass-card del tema\n",
        "AX_PLOT = 'rgba(6,48,82,0.45)'      # azul profundo semi-transparente\n",
        "GR_PLOT = 'rgba(93,214,240,0.12)'   # cuadrícula: cian muy suave\n",
        "TX_PLOT = '#cce8f4'                  # --text-main del tema\n",
        "\n",
        "# Colores por escenario (conservados del original — buen contraste sobre oscuro)\n",
        "ESCENARIOS = {\n",
        "    'inercial': {\n",
        "        'H': '#E8A838', 'P': '#E8A838',\n",
        "        'H_band': 'rgba(232,168,56,0.15)',\n",
        "        'P_band': 'rgba(232,168,56,0.15)',\n",
        "    },\n",
        "    'conservacion': {\n",
        "        'H': '#1DB38A', 'P': '#1DB38A',\n",
        "        'H_band': 'rgba(29,179,138,0.15)',\n",
        "        'P_band': 'rgba(29,179,138,0.15)',\n",
        "    },\n",
        "    'catastrofico': {\n",
        "        'H': '#E05C2A', 'P': '#E05C2A',\n",
        "        'H_band': 'rgba(224,92,42,0.15)',\n",
        "        'P_band': 'rgba(224,92,42,0.15)',\n",
        "    },\n",
        "}\n",
        "\n",
        "\n",
        "# ── 2. SIMULACIÓN ────────────────────────────────────────────────────────────\n",
        "\n",
        "def simular(ruido_hist_H, ruido_hist_P, ruido_fut_H, ruido_fut_P,\n",
        "            año_interv, factor_a, factor_f):\n",
        "    H = np.zeros(T)\n",
        "    P = np.zeros(T)\n",
        "    H[0], P[0] = H_OBS[0], P_OBS[0]\n",
        "    fi = 0\n",
        "    for t in range(T - 1):\n",
        "        futuro = AÑOS[t] >= año_interv\n",
        "        a_act  = A_M * factor_a if futuro else A_M\n",
        "        f_act  = F_M * factor_f if futuro else F_M\n",
        "        rH = ruido_fut_H[fi] if futuro else ruido_hist_H[t]\n",
        "        rP = ruido_fut_P[fi] if futuro else ruido_hist_P[t]\n",
        "        if futuro:\n",
        "            fi += 1\n",
        "        H[t+1] = np.clip(\n",
        "            H[t] * np.exp(R_M * (1 - H[t]/K) - a_act * P[t]) + rH,\n",
        "            0.001, 5.0)\n",
        "        P[t+1] = np.clip(\n",
        "            P[t] * np.exp(f_act * (1 - P[t]/C)) + rP,\n",
        "            0.001, 5.0)\n",
        "    return H, P\n",
        "\n",
        "\n",
        "def monte_carlo(año_interv, factor_a, factor_f, seed=42):\n",
        "    rng   = np.random.default_rng(seed)\n",
        "    H_arr = np.zeros((N_SIMS, T))\n",
        "    P_arr = np.zeros((N_SIMS, T))\n",
        "    for i in range(N_SIMS):\n",
        "        rH_h = rng.normal(0, SH_M, T)\n",
        "        rP_h = rng.normal(0, SP_M, T)\n",
        "        rH_f = rng.normal(0, SH_M, T)\n",
        "        rP_f = rng.normal(0, SP_M, T)\n",
        "        H_arr[i], P_arr[i] = simular(rH_h, rP_h, rH_f, rP_f,\n",
        "                                      año_interv, factor_a, factor_f)\n",
        "    def st(mat):\n",
        "        return dict(\n",
        "            med=np.median(mat, axis=0),\n",
        "            q5 =np.percentile(mat, 5,  axis=0),\n",
        "            q95=np.percentile(mat, 95, axis=0),\n",
        "        )\n",
        "    return st(H_arr), st(P_arr)\n",
        "\n",
        "\n",
        "# ── 3. PRE-CÓMPUTO DE LOS 3 ESCENARIOS ──────────────────────────────────────\n",
        "\n",
        "cfg = [\n",
        "    ('Escenario 1 — Inercial',\n",
        "     'Parámetros actuales sin intervención',\n",
        "     1.0, 1.0, 2025, 'inercial'),\n",
        "    ('Escenario 2 — Conservación',\n",
        "     'Regulación pesquera: −50% presión y −50% crecimiento de flota',\n",
        "     0.5, 0.5, 2030, 'conservacion'),\n",
        "    ('Escenario 3 — Catastrófico',\n",
        "     'Expansión no regulada: +40% presión y +40% crecimiento de flota',\n",
        "     1.4, 1.4, 2025, 'catastrofico'),\n",
        "]\n",
        "\n",
        "resultados = []\n",
        "for nombre, label, fa, ff, yr, tipo in cfg:\n",
        "    H_st, P_st = monte_carlo(yr, fa, ff)\n",
        "    resultados.append(dict(\n",
        "        nombre=nombre, label=label, fa=fa, ff=ff,\n",
        "        yr=yr, tipo=tipo, H=H_st, P=P_st\n",
        "    ))\n",
        "\n",
        "\n",
        "# ── 4. FUNCIÓN DE FIGURA ─────────────────────────────────────────────────────\n",
        "\n",
        "def hacer_figura(res):\n",
        "    tipo   = res['tipo']\n",
        "    col    = ESCENARIOS[tipo]\n",
        "    H_st   = res['H']\n",
        "    P_st   = res['P']\n",
        "    yr     = res['yr']\n",
        "    nombre = res['nombre']\n",
        "    label  = res['label']\n",
        "\n",
        "    años_l = list(AÑOS)\n",
        "    años_o = list(AÑOS_OBS)\n",
        "\n",
        "    # Métricas de comparación vs. inercial\n",
        "    h_fin_iner = float(np.mean(resultados[0]['H']['med'][-10:]))\n",
        "    h_fin_este = float(np.mean(H_st['med'][-10:]))\n",
        "    p_fin_iner = float(np.mean(resultados[0]['P']['med'][-10:]))\n",
        "    p_fin_este = float(np.mean(P_st['med'][-10:]))\n",
        "    delta_H = (h_fin_este - h_fin_iner) / max(h_fin_iner, 0.001) * 100\n",
        "    delta_P = (p_fin_este - p_fin_iner) / max(p_fin_iner, 0.001) * 100\n",
        "\n",
        "    fig = make_subplots(\n",
        "        rows=2, cols=1,\n",
        "        shared_xaxes=True,\n",
        "        vertical_spacing=0.10,\n",
        "        subplot_titles=[\n",
        "            'H — Biodiversidad marina (presa)',\n",
        "            'P — Flota pesquera (depredador)',\n",
        "        ],\n",
        "    )\n",
        "\n",
        "    # ── Panel H ──────────────────────────────────────────────────────────────\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_l + años_l[::-1],\n",
        "        y=list(H_st['q95']) + list(H_st['q5'])[::-1],\n",
        "        fill='toself', fillcolor=col['H_band'],\n",
        "        line=dict(width=0), showlegend=False, hoverinfo='skip',\n",
        "    ), row=1, col=1)\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_l, y=list(H_st['med']),\n",
        "        mode='lines', line=dict(color=col['H'], width=2.8),\n",
        "        name='Mediana H',\n",
        "        hovertemplate='%{x}: %{y:.3f}<extra>Mediana H</extra>',\n",
        "    ), row=1, col=1)\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_o, y=list(H_OBS),\n",
        "        mode='markers',\n",
        "        marker=dict(color='white', size=7, line=dict(color=col['H'], width=1.5)),\n",
        "        name='Datos históricos H',\n",
        "        hovertemplate='%{x}: %{y:.3f}<extra>Histórico</extra>',\n",
        "    ), row=1, col=1)\n",
        "\n",
        "    # ── Panel P ──────────────────────────────────────────────────────────────\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_l + años_l[::-1],\n",
        "        y=list(P_st['q95']) + list(P_st['q5'])[::-1],\n",
        "        fill='toself', fillcolor=col['P_band'],\n",
        "        line=dict(width=0), showlegend=False, hoverinfo='skip',\n",
        "    ), row=2, col=1)\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_l, y=list(P_st['med']),\n",
        "        mode='lines', line=dict(color=col['P'], width=2.8),\n",
        "        name='Mediana P',\n",
        "        hovertemplate='%{x}: %{y:.3f}<extra>Mediana P</extra>',\n",
        "    ), row=2, col=1)\n",
        "\n",
        "    fig.add_trace(go.Scatter(\n",
        "        x=años_o, y=list(P_OBS),\n",
        "        mode='markers',\n",
        "        marker=dict(color='white', size=7, line=dict(color=col['P'], width=1.5)),\n",
        "        name='Datos históricos P',\n",
        "        hovertemplate='%{x}: %{y:.3f}<extra>Histórico</extra>',\n",
        "    ), row=2, col=1)\n",
        "\n",
        "    # ── Líneas verticales de intervención ────────────────────────────────────\n",
        "    for row in (1, 2):\n",
        "        fig.add_vline(\n",
        "            x=yr,\n",
        "            line=dict(color='rgba(204,232,244,0.45)', width=1.5, dash='dot'),\n",
        "            row=row, col=1\n",
        "        )\n",
        "\n",
        "    # ── Anotaciones de métricas ───────────────────────────────────────────────\n",
        "    emoji_dH = '▲' if delta_H >= 0 else '▼'\n",
        "    emoji_dP = '▲' if delta_P >= 0 else '▼'\n",
        "\n",
        "    ann_style = dict(\n",
        "        showarrow=False,\n",
        "        font=dict(size=10, color=TX_PLOT),\n",
        "        bgcolor='rgba(4,30,53,0.88)',\n",
        "        bordercolor='rgba(93,214,240,0.25)',\n",
        "        borderwidth=1, borderpad=6, align='left',\n",
        "    )\n",
        "\n",
        "    fig.add_annotation(\n",
        "        xref='paper', yref='y',\n",
        "        x=0.01, y=float(H_st['med'][-1]) + 0.05,\n",
        "        xanchor='left', yanchor='bottom',\n",
        "        text=(f\"H final (2089-2098): <b>{h_fin_este:.3f}</b><br>\"\n",
        "              f\"vs. inercial: <b>{h_fin_iner:.3f}</b> \"\n",
        "              f\"<b>({emoji_dH} {abs(delta_H):.1f}%)</b>\"),\n",
        "        **ann_style\n",
        "    )\n",
        "\n",
        "    fig.add_annotation(\n",
        "        xref='paper', yref='y2',\n",
        "        x=0.01, y=float(P_st['med'][-1]) + 0.05,\n",
        "        xanchor='left', yanchor='bottom',\n",
        "        text=(f\"P final (2089-2098): <b>{p_fin_este:.3f}</b><br>\"\n",
        "              f\"vs. inercial: <b>{p_fin_iner:.3f}</b> \"\n",
        "              f\"<b>({emoji_dP} {abs(delta_P):.1f}%)</b>\"),\n",
        "        **ann_style\n",
        "    )\n",
        "\n",
        "    # ── Layout ───────────────────────────────────────────────────────────────\n",
        "    fig.update_layout(\n",
        "        plot_bgcolor=AX_PLOT,\n",
        "        paper_bgcolor=BG_PLOT,\n",
        "        font=dict(color=TX_PLOT, family='DM Sans, system-ui, sans-serif', size=11),\n",
        "        title=dict(\n",
        "            text=(f\"<b>{nombre}</b><br>\"\n",
        "                  f\"<span style='font-size:13px;color:{TX_PLOT};'>{label}</span>\"),\n",
        "            font=dict(size=16, color=TX_PLOT),\n",
        "            x=0.5, xanchor='center', y=0.97,\n",
        "        ),\n",
        "        height=660,\n",
        "        margin=dict(t=110, b=50, l=70, r=25),\n",
        "        hovermode='x unified',\n",
        "        legend=dict(\n",
        "            orientation='h', x=0.0, y=-0.08,\n",
        "            bgcolor='rgba(4,30,53,0.82)',\n",
        "            bordercolor='rgba(93,214,240,0.22)',\n",
        "            borderwidth=1, font=dict(size=10),\n",
        "        ),\n",
        "    )\n",
        "\n",
        "    ax_common = dict(\n",
        "        gridcolor=GR_PLOT,\n",
        "        linecolor='rgba(93,214,240,0.2)',\n",
        "        tickfont=dict(color=TX_PLOT, size=10),\n",
        "        range=[AÑO_INI - 1, AÑO_INI + T + 1],\n",
        "    )\n",
        "    for row in (1, 2):\n",
        "        fig.update_xaxes(**ax_common, showgrid=False, row=row, col=1)\n",
        "\n",
        "    fig.update_yaxes(\n",
        "        title_text='H normalizado', gridcolor=GR_PLOT,\n",
        "        linecolor='rgba(93,214,240,0.2)',\n",
        "        tickfont=dict(color=TX_PLOT, size=10),\n",
        "        rangemode='nonnegative', row=1, col=1,\n",
        "    )\n",
        "    fig.update_yaxes(\n",
        "        title_text='P normalizado', gridcolor=GR_PLOT,\n",
        "        linecolor='rgba(93,214,240,0.2)',\n",
        "        tickfont=dict(color=TX_PLOT, size=10),\n",
        "        rangemode='nonnegative', row=2, col=1,\n",
        "    )\n",
        "    fig.update_xaxes(title_text='Año', row=2, col=1)\n",
        "\n",
        "    # Subtítulos de subplots en color del tema\n",
        "    for ann in fig.layout.annotations:\n",
        "        if ann.text in ('H — Biodiversidad marina (presa)',\n",
        "                        'P — Flota pesquera (depredador)'):\n",
        "            ann.font.color = TX_PLOT\n",
        "            ann.font.size  = 12\n",
        "\n",
        "    return fig\n",
        "\n",
        "\n",
        "# ── 5. GENERAR FIGURAS ────────────────────────────────────────────────────────\n",
        "\n",
        "figs = [hacer_figura(res) for res in resultados]"
      ],
